    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "string.comment"
            ],
            "settings": {
                "foreground": "#5c6369"
            }
        },
        {
            "scope": [
                "constant.other.placeholder",
                "constant.character"
            ],
            "settings": {
                "foreground": "#cf222e"
            }
        },
        {
            "scope": [
                "constant",
                "entity.name.constant",
                "variable.other.constant",
                "variable.other.enummember",
                "variable.language",
                "entity"
            ],
            "settings": {
                "foreground": "#0550ae"
            }
        },
        {
            "scope": [
                "entity.name",
                "meta.export.default",
                "meta.definition.variable"
