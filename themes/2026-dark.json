                "fontStyle": "italic"
            }
        },
        {
            "scope": "entity.name.class",
            "settings": {
                "foreground": "#ffa657",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "entity.name.type.class",
            "settings": {
                "foreground": "#ffa657",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "entity.name.type",
            "settings": {
                "foreground": "#ffa657",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "entity.other.inherited-class",
