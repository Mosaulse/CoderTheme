    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "string.comment"
            ],
            "settings": {
                "foreground": "#9e9e9e",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Documentation Comments",
            "scope": [
                "comment.block.documentation",
                "comment.line.documentation"
            ],
            "settings": {
                "foreground": "#388e3c",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant.other.placeholder",
                "constant.character"
            ],
            "settings": {
                "foreground": "#8e24aa"
            }
        },
        {
            "scope": [
                "constant",
                "entity.name.constant",
                "variable.other.constant",
                "variable.other.enummember",
                "variable.language",
                "entity"
            ],
            "settings": {
                "foreground": "#7b1fa2"
            }
        },
        {
            "scope": [
                "entity.name",
                "meta.export.default",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#e65100"
            }
        },
        {
